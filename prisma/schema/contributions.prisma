model Contribution {
  id         String   @id @default(cuid())
  giver      String   @db.VarChar(100)
  amount     Float
  message    String?  @db.VarChar(200)
  wishItem   WishItem @relation("ContributionWishItem", fields: [wishItemId], references: [id], onDelete: Cascade)
  wishItemId String
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  createdAt  DateTime @default(now())

  @@index([wishItemId])
  @@index([createdAt])
  @@map("contributions")
}
